# AI Agent Container - Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Or use a preset:
#   cp .env.claude .env      # Claude Code only
#   cp .env.full .env        # All AI tools
#   cp .env.browsing .env    # Browsing + search

# ==============================================================================
# CLAUDE CODE AUTH — pick ONE method
# ==============================================================================

# Option 1: Direct Anthropic API key (pay-per-token)
# ANTHROPIC_API_KEY=sk-ant-...

# Option 2: OAuth token (Claude Pro/Team/Enterprise subscription)
# CLAUDE_CODE_OAUTH_TOKEN=...

# Option 3: LiteLLM proxy (route to any model via a local/remote proxy)
# ANTHROPIC_BASE_URL=http://localhost:4000
# ANTHROPIC_API_KEY=<your-litellm-master-key>

# Option 4: AWS Bedrock
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# ANTHROPIC_BASE_URL=https://bedrock-runtime.us-east-1.amazonaws.com

# Option 5: Google Vertex AI
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_CLOUD_PROJECT=my-project
# GOOGLE_CLOUD_REGION=us-east5

# ==============================================================================
# OTHER AI TOOLS
# ==============================================================================

# --- OpenAI (Codex, Aider, Shell-GPT) ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1   # override for proxies / local models

# --- Google (Gemini CLI) ---
# GOOGLE_API_KEY=...

# ==============================================================================
# MCP SERVERS & PLUGINS
# ==============================================================================

# --- GitHub (MCP server + github plugin) ---
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# --- Brave Search (MCP server) ---
# BRAVE_API_KEY=...

# --- BrightData (MCP server - web scraping/search) ---
# BRIGHTDATA_API_KEY=...

# --- Exa (MCP server - semantic/similarity search) ---
# EXA_API_KEY=...

# ==============================================================================
# OTHER TOOLS
# ==============================================================================

# --- Fabric (AI patterns) ---
# FABRIC_API_KEY=
