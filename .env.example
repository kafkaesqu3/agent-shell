# AI Agent Container - Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Or use a preset:
#   cp .env.claude .env      # Claude Code only
#   cp .env.full .env        # All AI tools
#   cp .env.browsing .env    # Browsing + search

# --- Anthropic (Claude Code, Aider) ---
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_CODE_OAUTH_TOKEN=

# --- OpenAI (Codex, Aider, Shell-GPT) ---
# OPENAI_API_KEY=sk-...

# --- Google (Gemini CLI) ---
# GOOGLE_API_KEY=

# --- GitHub (MCP server, gh CLI, Copilot) ---
# GITHUB_TOKEN=ghp_...

# --- Brave Search (MCP server) ---
# BRAVE_API_KEY=

# --- Fabric (AI patterns) ---
# FABRIC_API_KEY=
