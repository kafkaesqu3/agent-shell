# Claude Code only
# Copy to .env and fill in your key:  cp .env.claude .env

# --- Claude Code auth: pick ONE ---

# Option 1: Direct API key (pay-per-token)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Option 2: OAuth token (Pro/Team/Enterprise subscription)
# CLAUDE_CODE_OAUTH_TOKEN=REPLACE_ME

# Option 3: LiteLLM proxy
# ANTHROPIC_BASE_URL=http://localhost:4000
# ANTHROPIC_API_KEY=<litellm-master-key>

# Option 4: AWS Bedrock
# AWS_ACCESS_KEY_ID=REPLACE_ME
# AWS_SECRET_ACCESS_KEY=REPLACE_ME
# AWS_REGION=us-east-1

# Option 5: Google Vertex AI
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_CLOUD_PROJECT=REPLACE_ME
# GOOGLE_CLOUD_REGION=us-east5

# --- GitHub (plugin + MCP server) ---
# GITHUB_TOKEN=ghp_REPLACE_ME
