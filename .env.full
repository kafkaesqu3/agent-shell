# Full AI suite - all tools configured
# Copy to .env and fill in your keys:  cp .env.full .env

# --- Claude Code auth: pick ONE ---
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# CLAUDE_CODE_OAUTH_TOKEN=REPLACE_ME
# ANTHROPIC_BASE_URL=http://localhost:4000   # LiteLLM proxy

# --- OpenAI (Codex, Aider, Shell-GPT) ---
OPENAI_API_KEY=sk-REPLACE_ME
# OPENAI_BASE_URL=https://api.openai.com/v1  # override for proxies / local models

# --- Google (Gemini CLI) ---
GOOGLE_API_KEY=REPLACE_ME

# --- GitHub (MCP server + plugin) ---
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_REPLACE_ME

# --- Brave Search (MCP server) ---
BRAVE_API_KEY=REPLACE_ME

