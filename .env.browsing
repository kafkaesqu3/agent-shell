# Browsing + search configuration
# Best with: docker build --target browsing -t ai-agent-browsing .
# Copy to .env and fill in your keys:  cp .env.browsing .env

# --- Claude Code auth: pick ONE ---
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# CLAUDE_CODE_OAUTH_TOKEN=REPLACE_ME
# ANTHROPIC_BASE_URL=http://localhost:4000   # LiteLLM proxy

# --- GitHub (MCP server + plugin) ---
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_REPLACE_ME

# --- Brave Search (MCP server) ---
BRAVE_API_KEY=REPLACE_ME

# --- BrightData (MCP server - web search + scraping + residential proxies) ---
BRIGHTDATA_API_KEY=REPLACE_ME
