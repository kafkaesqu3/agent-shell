# Browsing + search configuration
# Best with: docker build --target browsing -t ai-agent-browsing .
# Copy to .env and fill in your keys:  cp .env.browsing .env

# Anthropic (required for Claude Code)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# GitHub (MCP server for repo access)
GITHUB_TOKEN=ghp_REPLACE_ME

# Brave Search (MCP server for web search)
BRAVE_API_KEY=REPLACE_ME
